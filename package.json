{
  "name": "awtb",
  "private": true,
  "workspaces": [
    "app",
    "sanity"
  ],
  "scripts": {
    "analyze": "ANALYZE=true next build --webpack",
    "prebuild": "npm run typegen",
    "build": "next build",
    "db:check": "drizzle-kit check",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "predev": "npm run typegen",
    "dev": "next dev",
    "docs": "typedoc",
    "docs:check": "node scripts/check-documentation.mjs && typedoc --emit none",
    "email:dev": "react-email dev --dir emails --port 3001",
    "env:check": "node scripts/check-env.mjs",
    "env:check:ci": "node scripts/check-env.mjs --example",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "observability:check": "node scripts/check-observability.mjs",
    "prepare": "husky",
    "quality:gate": "npm run type-check && npm run lint && npm run env:check && npm run docs:check && npm run observability:check && npm run test:coverage && npm run test:e2e:coverage && npm run build && npm run verify:start",
    "start": "next start",
    "test": "vitest run --passWithNoTests",
    "test:all": "vitest run --passWithNoTests && playwright test",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:coverage": "node scripts/check-e2e-coverage.mjs && playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "type-check": "npm run typegen && next typegen && tsc --noEmit",
    "typegen": "cd sanity && sanity schema extract --enforce-required-fields --path ../sanity.schema.json && sanity typegen generate",
    "verify:start": "node scripts/verify-start.mjs"
  },
  "overrides": {
    "@vercel/frameworks": {
      "js-yaml": "^3.15.0"
    },
    "esbuild": "^0.25.0",
    "jsdom": {
      "undici": "^7.25.0"
    },
    "typeid-js": {
      "uuid": "^11.1.1"
    },
    "undici": "^6.27.0"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.20",
    "@flags-sdk/posthog": "^0.2.2",
    "@neondatabase/serverless": "^1.1.0",
    "@portabletext/react": "^6.2.0",
    "@sanity/client": "^7.24.0",
    "@sanity/image-url": "^2.1.1",
    "@sanity/orderable-document-list": "^2.0.15",
    "@sanity/uuid": "^3.0.2",
    "@sentry/nextjs": "^10.67.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.4.1",
    "@vercel/edge-config": "^1.4.3",
    "@vercel/speed-insights": "^2.0.0",
    "autoprefixer": "^10.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "flags": "^4.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.21.0",
    "next": "^16.2.10",
    "next-sanity": "^13.1.4",
    "postcss": "^8.5.20",
    "posthog-js": "^1.404.1",
    "posthog-node": "^5.45.2",
    "radix-ui": "^1.6.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-email": "^6.6.3",
    "resend": "^6.14.0",
    "sanity": "^5.31.1",
    "sanity-image": "^1.1.0",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "styled-components": "^6.4.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.10",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "checkly": "latest",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typedoc": "^0.28.20",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.10"
  }
}
