# =============================================================================
# awtb — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to git.
#
# How to get each value:
# 1. Run: vercel link && vercel env pull .env.local
# 2. Sensitive vars are NOT included in the pull — add them manually below.
# 3. Find sensitive values in: vercel.com → awtb project → Settings → Env Vars
# =============================================================================

# -----------------------------------------------------------------------------
# Sanity CMS
# Project: https://sanity.io/manage → d205mlci
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SANITY_PROJECT_ID="d205mlci"
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2026-06-01"
SANITY_API_DATASET="production"
SANITY_API_PROJECT_ID="d205mlci"
SANITY_STUDIO_DATASET="production"
SANITY_STUDIO_PROJECT_ID="d205mlci"

# Sanity API tokens — generate at: sanity.io/manage → API → Tokens
SANITY_API_READ_TOKEN=
SANITY_API_WRITE_TOKEN=

# Sanity webhook HMAC secret — generate a random string:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SANITY_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Vercel Storage
# -----------------------------------------------------------------------------

# Vercel Edge Config — auto-populated by Vercel integration
EDGE_CONFIG=

# Vercel Blob — get from: vercel.com → Storage → Blob store → Tokens
BLOB_STORE_ID="store_PkStfibbIuX2s6R1"
BLOB_READ_WRITE_TOKEN=

# Upstash Redis (via Vercel KV integration)
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_URL=
KV_REST_API_READ_ONLY_TOKEN=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Vercel OIDC — auto-populated by Vercel
VERCEL_OIDC_TOKEN=

# -----------------------------------------------------------------------------
# Sentry Error Monitoring
# Project: https://awtb-monitoring.sentry.io/projects/awtb-sentry/
# Setup: vercel.com → Integrations → Sentry
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG="awtb-monitoring"
SENTRY_PROJECT="awtb-sentry"
SENTRY_PUBLIC_KEY=
SENTRY_OTLP_TRACES_URL=
SENTRY_VERCEL_LOG_DRAIN_URL=

# -----------------------------------------------------------------------------
# PostHog Analytics & Feature Flags
# Setup: vercel.com → Integrations → PostHog
# Dashboard: https://app.posthog.com
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST="https://us.posthog.com"

# PostHog personal API key — for feature flags SDK
# Generate at: app.posthog.com → Settings → Personal API Keys
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=

# -----------------------------------------------------------------------------
# Clerk Authentication
# Setup: vercel.com → Integrations → Clerk
# Dashboard: https://dashboard.clerk.com
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# -----------------------------------------------------------------------------
# Checkly Synthetic Monitoring
# Setup: vercel.com → Integrations → Checkly
# Dashboard: https://app.checklyhq.com
# -----------------------------------------------------------------------------
CHECKLY_API_KEY=
CHECKLY_ACCOUNT_ID=

